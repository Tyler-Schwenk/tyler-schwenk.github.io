# JWT Secret Key
# Generate with: openssl rand -hex 32
JWT_SECRET=your-secret-key-here-change-this-in-production

# Public Square IP hash salt — mixed into visitor IPs before hashing for
# anonymous vote/spam dedup. Raw IPs are never stored.
# Generate with: openssl rand -hex 32
IP_HASH_SALT=your-salt-here-change-this-in-production

# CORS Origins (comma-separated list of allowed origins)
# Add your GitHub Pages frontend URL
CORS_ORIGINS=https://yourusername.github.io,http://localhost:3000
